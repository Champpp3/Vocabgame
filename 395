        };

        function App() {
            const [view, setView] = useState('MENU');
            const [isDark, setIsDark] = useState(true);
            const [showSetting, setShowSetting] = useState(false);
            const [isPractice, setIsPractice] = useState(false);
            const [showRanking, setShowRanking] = useState(false);
            const [playerName, setPlayerName] = useState('');
            const [score, setScore] = useState(0);
            const [currentWord, setCurrentWord] = useState(null);
            const [options, setOptions] = useState([]);
            const [answered, setAnswered] = useState(false);
            const [correctChoice, setCorrectChoice] = useState(null);
            const [globalBoard, setGlobalBoard] = useState([]);

            useEffect(() => {
                document.body.className = isDark ? 'theme-dark' : 'theme-light';
            }, [isDark]);

            useEffect(() => {
                if (!window.db || !window.dbUtils) return;
                const { ref, onValue, query, orderByChild } = window.dbUtils;
                onValue(query(ref(window.db, 'scores'), orderByChild('score')), (snap) => {
                    if (snap.val()) setGlobalBoard(Object.values(snap.val()).sort((a, b) => b.score - a.score));
                });
            }, []);

            const nextQuestion = () => {
                const keys = Object.keys(vocabData);
                const word = keys[Math.floor(Math.random() * keys.length)];
                const correct = vocabData[word];
                let choices = [correct];
                while(choices.length < 4) {
                    const r = Object.values(vocabData)[Math.floor(Math.random() * Object.values(vocabData).length)];
                    if(!choices.includes(r)) choices.push(r);
                }
                setOptions(choices.sort(() => Math.random() - 0.5));
                setCurrentWord(word);
                setCorrectChoice(correct);
                setAnswered(false);
            };

            const startGame = (mode) => {
                if (mode === 'RANKED' && !playerName.trim()) return alert("กรุณาใส่ชื่อเพื่อจัดอันดับครับ");
                setIsPractice(mode === 'PRACTICE');
                setScore(0);
                nextQuestion();
                setView('PLAY');
            };

            const handleAnswer = (choice) => {
                if (answered) return;
                setAnswered(true);
                if (choice === correctChoice) {
                    setScore(s => s + 1);
                    setTimeout(nextQuestion, 600);
                } else {
                    if (!isPractice && window.db && score > 0) {
                        const { ref, push, set } = window.dbUtils;
                        set(push(ref(window.db, 'scores')), { name: playerName, score, timestamp: Date.now() });
                    }
                    setTimeout(() => setView('GAMEOVER'), 1000);
                }
            };

            return (
                <div className="min-h-screen flex items-center justify-center p-4">
                    <button onClick={() => setShowSetting(true)} className="fixed top-6 left-6 z-50 w-12 h-12 glass rounded-full flex items-center justify-center text-xl shadow-lg">⚙️</button>

                    {view === 'MENU' && (
                        <div className="w-full max-w-md glass p-10 rounded-[3rem] text-center anim-in">
                            <h1 className="text-4xl font-black mb-8 tracking-widest text-sky-500"> Vocab Quiz</h1>
                            <input className="w-full p-5 bg-white/5 rounded-2xl mb-4 text-center text-xl font-bold border border-white/10 text-white" placeholder="ใส่ชื่อของคุณ" value={playerName} onChange={e => setPlayerName(e.target.value)} />
                            <div className="grid gap-3">
                                <button onClick={() => startGame('RANKED')} className="w-full py-5 btn-primary rounded-2xl font-black text-xl shadow-xl transition-transform hover:scale-105 active:scale-95">RANKED PLAY</button>
                                <button onClick={() => startGame('PRACTICE')} className="w-full py-5 bg-white/10 rounded-2xl font-black text-xl text-white border border-white/10 hover:bg-white/20 transition-all">PRACTICE (ไม่บันทึกคะแนน)</button>
                            </div>
                            <button onClick={() => setShowRanking(true)} className="mt-8 block w-full text-yellow-400 font-bold hover:underline">🏆 LEADERBOARD</button>
                        </div>
                    )}

                    {view === 'PLAY' && (
                        <div className="w-full max-w-xl text-center anim-in">
                            <div className="flex justify-between mb-8 px-4 font-bold text-white">
                                <span className="opacity-60">{isPractice ? "🛠 โหมดฝึกซ้อม" : playerName}</span>
                                <span className="text-2xl text-red-500">SCORE: {score}</span>
                            </div>
                            <div className="glass p-10 rounded-[3rem] shadow-2xl border-white/20">
                                <h2 className="text-5xl font-black mb-12 text-white drop-shadow-md">{currentWord}</h2>
                                <div className="grid gap-4">
                                    {options.map((opt, i) => (
                                        <button key={i} onClick={() => handleAnswer(opt)} className={`p-5 rounded-2xl border-2 font-bold text-lg transition-all ${answered ? (opt === correctChoice ? 'bg-emerald-500 border-emerald-400 text-white scale-105' : 'opacity-20 text-white') : 'hover:border-sky-500 text-white hover:bg-white/5 active:bg-sky-900'}`}>{opt}</button>
                                    ))}
                                </div>
                            </div>
                        </div>
                    )}

                    {view === 'GAMEOVER' && (
                        <div className="w-full max-w-md glass p-12 rounded-[3rem] text-center anim-in text-white shadow-2xl">
                            <h2 className="text-3xl font-black text-red-500 mb-2 uppercase tracking-tighter">จบเกม!</h2>
                            <div className="text-8xl font-black mb-10 text-sky-500 drop-shadow-lg">{score}</div>
                            <button onClick={() => setView('MENU')} className="w-full py-5 btn-primary rounded-2xl font-black text-2xl shadow-lg">กลับหน้าหลัก</button>
                        </div>
                    )}

                    {showSetting && (
                        <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-md" onClick={() => setShowSetting(false)}>
                            <div className="w-80 glass p-8 rounded-3xl text-white border border-white/20 shadow-2xl" onClick={e => e.stopPropagation()}>
                                <h3 className="text-xl font-bold mb-6 text-center text-sky-400">SETTINGS</h3>
                                <button onClick={() => setIsDark(!isDark)} className="w-full py-4 bg-white/10 rounded-xl mb-4 font-bold">{isDark ? '🌙 DARK MODE' : '☀️ LIGHT MODE'}</button>
                                <button onClick={() => setShowSetting(false)} className="w-full py-4 bg-sky-600 rounded-xl font-black shadow-lg">CLOSE</button>
                            </div>
                        </div>
                    )}

                    {showRanking && (
                        <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 p-4" onClick={() => setShowRanking(false)}>
                            <div className="w-full max-w-md glass rounded-[2.5rem] h-[70vh] overflow-hidden flex flex-col text-white shadow-2xl" onClick={e => e.stopPropagation()}>
                                <div className="bg-sky-600 p-6 text-center font-black text-2xl italic tracking-widest">RANKING</div>
                                <div className="flex-1 overflow-y-auto p-4 space-y-2">
                                    {globalBoard.length > 0 ? globalBoard.map((e, i) => (
                                        <div key={i} className="flex justify-between items-center p-4 bg-white/5 rounded-2xl border border-white/5">
                                            <div className="flex items-center gap-3">
                                                <span className={`w-8 h-8 rounded-full flex items-center justify-center font-bold ${i < 3 ? 'bg-yellow-500 text-black' : 'bg-white/10 text-white'}`}>{i+1}</span>
                                                <span className="font-bold text-lg">{e.name}</span>
                                            </div>
                                            <span className="text-sky-400 font-black text-xl">{e.score}</span>
                                        </div>
                                    )) : <div className="text-center opacity-40 mt-10">ยังไม่มีข้อมูลคะแนน</div>}
                                </div>
                                <button onClick={() => setShowRanking(false)} className="p-5 bg-white/5 font-black text-red-400 hover:bg-white/10">CLOSE</button>
                            </div>
                        </div>
                    )}
                </div>
            );
        }
        ReactDOM.createRoot(document.getElementById('root')).render(<App />);
    </script>
</body>
</html>
